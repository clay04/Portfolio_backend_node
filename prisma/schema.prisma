// prisma/schema.prisma
// Jalankan: npx prisma migrate dev --name init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ── Metadata setiap sesi chat ─────────────────────────────────────────────────
// Dipakai untuk monitoring & insight (bukan untuk login)
model ChatSession {
  id           String   @id  // UUID yang dibuat di frontend
  ipHash       String       // IP yang sudah di-hash (privasi terjaga)
  userAgent    String       // Browser/device info
  deviceType   String       // "mobile" atau "desktop"
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

// ── Statistik harian per IP (untuk rate limiting & monitoring) ────────────────
model DailyIpStat {
  id           String   @id @default(uuid())
  ipHash       String
  date         String   // Format: "2025-01-15"
  messageCount Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([ipHash, date]) // Satu record per IP per hari
}

// ── Statistik global harian (untuk dashboard insight) ────────────────────────
model DailyStat {
  id              String   @id @default(uuid())
  date            String   @unique // Format: "2025-01-15"
  totalMessages   Int      @default(0)
  totalSessions   Int      @default(0)
  mobileUsers     Int      @default(0)
  desktopUsers    Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}
